#!/bin/bash
# ~/.config/polybar/scripts/powermenu_alt
# Variante del powermenu: mismo comportamiento que `powermenu` pero con tema
# rasi distinto (powermenu_alt.rasi) y prompt "System" en lugar del uptime.
# Es el script que dispara el módulo `sysmenu` de polybar (click izquierdo
# en el botón circular de la esquina derecha; ver current.ini → [module/sysmenu]).

# ----- COMANDO ROFI BASE -----
rofi_command="rofi -theme $HOME/.config/polybar/scripts/themes/powermenu_alt.rasi"

# Uptime sin el prefijo "up " (queda calculado aunque este script no lo muestre,
# por simetría con powermenu y por si quieres añadirlo al prompt).
uptime=$(uptime -p | sed -e 's/up //g')

# ----- OPCIONES -----
# Cada string comienza con un icono Nerd Font.
shutdown=" Shutdown"
reboot=" Restart"
lock=" Lock"
suspend=" Sleep"
logout=" Logout"

# Orden de aparición en rofi.
options="$lock\n$suspend\n$logout\n$reboot\n$shutdown"

# Prompt fijo "System" (la variante con uptime es powermenu, no este).
chosen="$(echo -e "$options" | $rofi_command -p "System" -dmenu -selected-row 0)"

# ----- ACCIÓN SEGÚN LA OPCIÓN ELEGIDA -----
case $chosen in
    $shutdown)
        systemctl poweroff
        ;;
    $reboot)
        systemctl reboot
        ;;
    $lock)
        i3lock
        ;;
    $suspend)
        # Pausar mpd y silenciar antes de suspender; evita audio fantasma al despertar.
        mpc -q pause
        amixer set Master mute
        systemctl suspend
        ;;
    $logout)
        # Cierra la sesión de bspwm (vuelve al login manager).
        bspc quit
        ;;
esac
