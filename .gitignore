# === Backups creados durante migración ===
*.bak
*.pre-dotfiles.bak

# === Editor temp files ===
*.swp
*.swo
*~

# === OS junk ===
.DS_Store
Thumbs.db
desktop.ini

# === Asistentes de IA / agentes ===
# CLAUDE.md SÍ se versiona (lo leen Claude Code, Cursor, etc. para entender
# las convenciones del proyecto al abrirlo). Lo que sí se ignora son los
# directorios .claude/, .cursor/, etc. que contienen preferencias personales
# del usuario sobre el agente y no aportan nada compartirlas.
.claude/
.cursor/
.aider*
.windsurfrules

# === Log files ===
*.log

# === Cache de aplicaciones ===
.cache/
*.cache

# === Datos sensibles (NUNCA commitear) ===
.env
.env.*
*.key
*.pem
*_rsa
*_dsa
*_ed25519
secrets/
.config/bin/target

# === Fuentes pesadas (opcional, comentar si quieres incluirlas) ===
# polybar/.config/polybar/fonts/

# === Lock files que crean ruido (excepto los importantes) ===
# Nvim: SÍ versionamos lazy-lock.json (versiones reproducibles)
# Polybar/picom: nada que ignorar

# === Logs generados por scripts ===
*.tmp
*.swp

